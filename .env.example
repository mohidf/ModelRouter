# ─────────────────────────────────────────────────────────────────────────────
# ModelRouter — environment variables
#
# Copy this file to backend/.env and fill in your values.
# NEVER commit .env files to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Logging ───────────────────────────────────────────────────────────────────
# Levels: debug | info | warn | error
LOG_LEVEL=info

# ── Routing config ────────────────────────────────────────────────────────────
# EMA smoothing factor for performance tracking (0 < alpha ≤ 1)
EMA_ALPHA=0.2

# Max real provider API calls per hour (protects against runaway costs)
MAX_REAL_REQUESTS_PER_HOUR=50

# ── Provider API keys ─────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
