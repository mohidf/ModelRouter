# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Logging ───────────────────────────────────────────────────────────────────
# Levels: debug | info | warn | error
LOG_LEVEL=info

# ── Routing config ────────────────────────────────────────────────────────────
# EMA smoothing factor for performance tracking (0 < alpha ≤ 1)
EMA_ALPHA=0.2

# Max real provider API calls allowed per hour (circuit-breaker protection)
RATE_LIMIT_PER_HOUR=50

# Escalation confidence threshold (0–1).
# When classifier confidence is below this, the request is retried with a
# higher-tier model. Default 0.6 suits the rule-based classifier (returns 0.7–1.0).
# The hybrid/embedding classifier uses a margin-based formula (top-second)/top
# which returns 0.05–0.70. Set to 0.20 for the hybrid classifier: only escalate
# when the top domain is less than 20% better than the runner-up (genuinely ambiguous).
CONFIDENCE_THRESHOLD=0.20

# ── Per-domain scoring weight overrides (optional) ────────────────────────────
# Format: confidence:<float>,cost:<float>,latency:<float>,escalation:<float>
# Example: CODE_WEIGHTS=confidence:2.0,cost:5.0,latency:0.001,escalation:1.5
CODE_WEIGHTS=
MATH_WEIGHTS=
CREATIVE_WEIGHTS=
GENERAL_WEIGHTS=
RESEARCH_WEIGHTS=
SUMMARIZATION_WEIGHTS=
VISION_WEIGHTS=
CODING_DEBUG_WEIGHTS=
GENERAL_CHAT_WEIGHTS=
MULTILINGUAL_WEIGHTS=
MATH_REASONING_WEIGHTS=

# ── Provider API keys ─────────────────────────────────────────────────────────
# Obtain from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Obtain from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Together AI — primary provider for most domains (open-source models)
# Obtain from: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=

# Reserved for future providers
GOOGLE_API_KEY=
COHERE_API_KEY=

# ── Supabase ──────────────────────────────────────────────────────────────────
# Your project URL from: https://supabase.com/dashboard → Settings → API
SUPABASE_URL=

# Service-role key — used by the backend to bypass Row Level Security.
# Found at: Supabase dashboard → Settings → API → "service_role" (secret)
# WARNING: Never expose this key in the browser or commit it to version control.
SUPABASE_SERVICE_ROLE_KEY=
