# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Logging ───────────────────────────────────────────────────────────────────
# Levels: debug | info | warn | error
LOG_LEVEL=info

# ── Routing config ────────────────────────────────────────────────────────────
# EMA smoothing factor for performance tracking (0 < alpha ≤ 1)
EMA_ALPHA=0.2

# Max real provider API calls allowed per hour (circuit-breaker protection)
RATE_LIMIT_PER_HOUR=50

# ── Per-domain scoring weight overrides (optional) ────────────────────────────
# Format: confidence:<float>,cost:<float>,latency:<float>,escalation:<float>
# Example: CODE_WEIGHTS=confidence:2.0,cost:5.0,latency:0.001,escalation:1.5
CODE_WEIGHTS=
MATH_WEIGHTS=
CREATIVE_WEIGHTS=
GENERAL_WEIGHTS=

# ── Provider API keys ─────────────────────────────────────────────────────────
# Obtain from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Obtain from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Reserved for future providers
GOOGLE_API_KEY=
COHERE_API_KEY=

# ── Supabase ──────────────────────────────────────────────────────────────────
# Your project URL from: https://supabase.com/dashboard → Settings → API
SUPABASE_URL=

# Service role key (keep secret — full DB access, never expose to clients)
SUPABASE_SERVICE_ROLE_KEY=
