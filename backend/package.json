{
  "name": "model-router-ai-backend",
  "version": "1.0.0",
  "description": "ModelRouter AI — intelligent LLM routing backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:db": "ts-node src/scripts/testConnection.ts",
    "benchmark": "ts-node src/scripts/benchmark.ts",
    "reset:stats": "ts-node src/scripts/resetStats.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@supabase/supabase-js": "^2.98.0",
    "@types/cors": "^2.8.19",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "openai": "^6.25.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.14.0",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.2"
  }
}
